{
  "description": "muninn-cc hooks — PreToolUse augments Grep/Read/Glob; UserPromptSubmit pre-injects project context once per user turn.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.sh",
            "timeout": 1
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
